# Copia este ficheiro para infra/.env e preenche com as tuas chaves
# cp infra/.env.example infra/.env

# Meta (WhatsApp Cloud API)
# Obtém em: https://developers.facebook.com → o teu App → WhatsApp → API Setup
META_VERIFY_TOKEN=escolhe-um-token-qualquer
META_APP_SECRET=app_secret_do_painel_meta
META_ACCESS_TOKEN=token_de_acesso_permanente_meta

# Anthropic (Claude)
# Obtém em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
